QUOTATION_API_ENDPOINT=http://economia.awesomeapi.com.br/json/last/USD-BRL

# Directory where recordings are saved (default: ~/MeetRecordings)
# RECORDINGS_DIR=~/MeetRecordings

# Name of the Multi-Output Device created in Audio MIDI Setup (default: Multi-Output (BlackHole))
# MULTI_OUTPUT_DEVICE_NAME=Multi-Output (BlackHole)

# RMS threshold below which the system-audio channel is considered silent (default: 0.001)
# SILENCE_RMS_THRESHOLD=0.001

# Seconds of sustained silence on the system-audio channel before warning (default: 30)
# SILENCE_WINDOW_SECONDS=30

# API key for OpenRouter, used for transcription and title/summary generation.
# Required for the `transcribe` command / menu bar transcription. Never set in config.yaml.
OPENROUTER_API_KEY=