<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
    <dict>
        <key>Label</key>
        <string>com.alisson.obs-transcribe</string>

        <key>EnvironmentVariables</key>
        <dict>
            <key>PATH</key>
            <string>/opt/homebrew/bin:/opt/homebrew/sbin:/usr/local/bin:/usr/bin:/bin</string>
            <key>HOME</key>
            <string>/Users/85750</string>
        </dict>

        <key>ProgramArguments</key>
        <array>
            <string>/Users/85750/wo/personal/obs-transcript/run-transcribe.sh</string>
        </array>

        <key>StartInterval</key>
        <integer>300</integer>

        <key>StandardOutPath</key>
        <string>/tmp/com.alisson.obs-transcribe.out</string>
        <key>StandardErrorPath</key>
        <string>/tmp/com.alisson.obs-transcribe.err</string>
    </dict>
</plist>
